# KRONOS — Zmienne środowiskowe
# Skopiuj ten plik jako .env i wypełnij prawdziwymi danymi
# NIGDY nie commituj .env do git!

# ── Twój klucz prywatny MetaMask ──────────────────────────────────
# Znajdziesz go w MetaMask: Menu → Account Details → Export Private Key
# Format: 0x + 64 znaki hex
POLY_PRIVATE_KEY=0xtutaj_wklej_swoj_klucz_prywatny

# ── Polymarket API Credentials ────────────────────────────────────
# Generujesz je raz skryptem generate-keys.ts (patrz niżej)
POLY_API_KEY=tutaj_api_key
POLY_API_SECRET=tutaj_api_secret
POLY_API_PASSPHRASE=tutaj_passphrase

# ── Tryb działania ────────────────────────────────────────────────
# DRY_RUN=true  → symuluje trade, nie wysyła zleceń (bezpieczne)
# DRY_RUN=false → prawdziwy handel (UWAGA: wydaje prawdziwe USDC!)
DRY_RUN=true
